*.mv.db
*.trace.db
*.lock.db

# Large/raw dataset files are intentionally not tracked.
documents/data/*
!documents/data/README.md
backend/src/main/resources/data/*
!backend/src/main/resources/data/README.md
documents/chat_history/
documents/demo/*.docx

