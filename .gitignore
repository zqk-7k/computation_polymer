# Runtime logs
*.log
logs/
output/

# Java / Maven build output
backend/target/
*.class
*.jar

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Python caches and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# IDE / OS files
.idea/
.vscode/
.claude/settings.local.json
.DS_Store
Thumbs.db

